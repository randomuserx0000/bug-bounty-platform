# Copia a .env para desarrollo local. Nunca commitear .env real.

BIND_ADDR=127.0.0.1:8080
PUBLIC_URL=http://localhost:8080

DATABASE_URL=postgres://bb:bb@localhost:5432/bugbounty
DB_MAX_CONN=10

# 32 bytes en hex — openssl rand -hex 32
PAYMENT_METHODS_KEY_HEX=changeme_changeme_changeme_changeme_changeme_changeme_change_me

# 64 bytes en hex — openssl rand -hex 64
COOKIE_KEY_HEX=changeme_changeme_changeme_changeme_changeme_changeme_changeme_changeme_changeme_changeme_changeme_changeme_changeme_changeme_

RUST_LOG=info,bugbounty=debug,sqlx=warn,tower_http=info

# --- Object storage (MinIO en docker-compose o S3/Hetzner en prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=bb-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin-dev-only
S3_FORCE_PATH_STYLE=true

# --- Google Sign-In (opcional) ---
# Crear credenciales en https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
